<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.portfolio.siemlite.controller.MainController"
            styleClass="root">
    <top>
        <VBox spacing="12" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="18" right="20" bottom="12" left="20"/>
            </padding>
            <Label text="SIEM Lite" styleClass="app-title"/>
            <HBox spacing="10">
                <Button fx:id="importButton" text="Importar log" onAction="#onImportLog"/>
                <TextField fx:id="searchField" promptText="Filtrar por texto, fuente, keyword o mensaje" HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="severityComboBox" prefWidth="160"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="eventsTable" BorderPane.alignment="CENTER">
            <columns>
                <TableColumn fx:id="lineNumberColumn" text="#" prefWidth="70"/>
                <TableColumn fx:id="timestampColumn" text="Timestamp" prefWidth="165"/>
                <TableColumn fx:id="severityColumn" text="Severidad" prefWidth="105"/>
                <TableColumn fx:id="sourceColumn" text="Fuente" prefWidth="140"/>
                <TableColumn fx:id="suspiciousColumn" text="Sospechoso" prefWidth="110"/>
                <TableColumn fx:id="keywordColumn" text="Keyword" prefWidth="120"/>
                <TableColumn fx:id="messageColumn" text="Mensaje" prefWidth="470"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10" BorderPane.alignment="CENTER_LEFT" styleClass="status-bar">
            <padding>
                <Insets top="10" right="20" bottom="12" left="20"/>
            </padding>
            <Label fx:id="statusLabel" text="Importá un archivo .log o .txt para comenzar."/>
        </HBox>
    </bottom>
</BorderPane>
